<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    
    <!-- Overdrive Dark Theme - Matching Web UI -->
    <style name="Theme.Overdrive" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary colors - Teal/Cyan brand -->
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/bg_base</item>
        <item name="colorPrimaryContainer">@color/brand_secondary</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>
        
        <!-- Secondary colors -->
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/bg_base</item>
        <item name="colorSecondaryContainer">@color/bg_elevated</item>
        <item name="colorOnSecondaryContainer">@color/text_primary</item>
        
        <!-- Tertiary colors -->
        <item name="colorTertiary">@color/status_danger</item>
        <item name="colorOnTertiary">@color/white</item>
        
        <!-- Background colors -->
        <item name="android:colorBackground">@color/bg_base</item>
        <item name="colorOnBackground">@color/text_primary</item>
        
        <!-- Surface colors -->
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/bg_elevated</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        
        <!-- Error colors -->
        <item name="colorError">@color/status_danger</item>
        <item name="colorOnError">@color/white</item>
        
        <!-- Status bar -->
        <item name="android:statusBarColor">@color/bg_base</item>
        <item name="android:navigationBarColor">@color/bg_base</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Window -->
        <item name="android:windowBackground">@color/bg_base</item>
        
        <!-- Material Components Styling -->
        <item name="materialCardViewStyle">@style/Widget.Overdrive.CardView</item>
        <item name="materialButtonStyle">@style/Widget.Overdrive.Button</item>
        <item name="switchStyle">@style/Widget.Overdrive.Switch</item>
        <item name="toolbarStyle">@style/Widget.Overdrive.Toolbar</item>
        <item name="sliderStyle">@style/Widget.Overdrive.Slider</item>
        <item name="checkboxStyle">@style/Widget.Overdrive.Checkbox</item>
        
        <!-- Text Appearance -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_muted</item>
    </style>
    
    <!-- Card Style - Clean with subtle border -->
    <style name="Widget.Overdrive.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/bg_surface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/card_border</item>
        <item name="strokeWidth">1dp</item>
    </style>
    
    <!-- Outlined Card Style -->
    <style name="Widget.Overdrive.CardView.Outlined" parent="Widget.Overdrive.CardView">
        <item name="cardCornerRadius">12dp</item>
    </style>
    
    <!-- Button Style - Primary -->
    <style name="Widget.Overdrive.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/button_primary_background</item>
        <item name="android:textColor">@color/button_primary_text</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <!-- Button Style - Outlined -->
    <style name="Widget.Overdrive.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/card_border</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>
    
    <!-- Button Style - Text -->
    <style name="Widget.Overdrive.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/brand_primary</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
    </style>
    
    <!-- Toggle Button Group -->
    <style name="Widget.Overdrive.ButtonToggleGroup" parent="Widget.Material3.MaterialButtonToggleGroup">
        <item name="singleSelection">true</item>
        <item name="selectionRequired">true</item>
    </style>
    
    <!-- Toggle Button -->
    <style name="Widget.Overdrive.Button.Toggle" parent="Widget.Material3.Button.OutlinedButton">
        <item name="backgroundTint">@color/toggle_button_background</item>
        <item name="strokeColor">@color/toggle_button_stroke</item>
        <item name="android:textColor">@color/toggle_button_text</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">13sp</item>
    </style>
    
    <!-- Switch Style -->
    <style name="Widget.Overdrive.Switch" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="trackTint">@color/switch_track_selector</item>
        <item name="thumbTint">@color/switch_thumb_selector</item>
    </style>
    
    <!-- Slider Style -->
    <style name="Widget.Overdrive.Slider" parent="Widget.Material3.Slider">
        <item name="trackColorActive">@color/brand_primary</item>
        <item name="trackColorInactive">@color/bg_hover</item>
        <item name="thumbColor">@color/brand_primary</item>
        <item name="haloColor">@color/brand_cyan_glow</item>
        <item name="tickColorActive">@color/brand_primary</item>
        <item name="tickColorInactive">@color/bg_hover</item>
    </style>
    
    <!-- Checkbox Style -->
    <style name="Widget.Overdrive.Checkbox" parent="Widget.Material3.CompoundButton.CheckBox">
        <item name="buttonTint">@color/brand_primary</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <!-- Toolbar Style -->
    <style name="Widget.Overdrive.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/bg_surface</item>
        <item name="titleTextColor">@color/text_primary</item>
    </style>
    
    <!-- Text Styles -->
    <style name="TextAppearance.Overdrive.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">20sp</item>
    </style>
    
    <style name="TextAppearance.Overdrive.Subtitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">16sp</item>
    </style>
    
    <style name="TextAppearance.Overdrive.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>
    
    <style name="TextAppearance.Overdrive.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">12sp</item>
    </style>
    
    <style name="TextAppearance.Overdrive.Label" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">13sp</item>
    </style>
    
    <style name="TextAppearance.Overdrive.Value" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/brand_primary</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <!-- Legacy theme aliases for compatibility -->
    <style name="Theme.CamExploit" parent="Theme.Overdrive" />
    <style name="Theme.BydChamp" parent="Theme.Overdrive" />
    
    <!-- Full Screen Dialog Theme -->
    <style name="Theme.Overdrive.FullScreenDialog" parent="Theme.Overdrive">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowBackground">@color/bg_base</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>
    
    <!-- Dialog Theme (dark, matching app style) -->
    <style name="Theme.Overdrive.Dialog" parent="Theme.Material3.Dark.Dialog.Alert">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/bg_base</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/bg_surface</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.Overdrive.DialogButton</item>
    </style>
    
    <style name="Widget.Overdrive.DialogButton" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/brand_primary</item>
    </style>
    
    <!-- Time Picker Dialog Theme -->
    <style name="Theme.Overdrive.TimePicker" parent="ThemeOverlay.Material3.MaterialTimePicker">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/bg_base</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
    </style>
    
    <!-- Bottom Sheet Theme -->
    <style name="Theme.Overdrive.BottomSheet" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.Overdrive.BottomSheet</item>
    </style>
    
    <style name="Widget.Overdrive.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="backgroundTint">@color/bg_surface</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Overdrive.LargeComponent</item>
    </style>
    
    <!-- Shape Appearances -->
    <style name="ShapeAppearance.Overdrive.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">8dp</item>
    </style>
    
    <style name="ShapeAppearance.Overdrive.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">12dp</item>
    </style>
    
    <style name="ShapeAppearance.Overdrive.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">16dp</item>
    </style>
    
</resources>
