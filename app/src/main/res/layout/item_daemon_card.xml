<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/bg_surface"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/card_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Main Row -->
        <LinearLayout
            android:id="@+id/mainRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <!-- Status Indicator with glow effect -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                
                <View
                    android:id="@+id/statusGlow"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:alpha="0.4"
                    android:background="@drawable/status_glow" />
                
                <View
                    android:id="@+id/statusIndicator"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_gravity="center"
                    android:background="@drawable/status_indicator" />
            </FrameLayout>

            <!-- Daemon Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDaemonName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daemon Name"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDaemonStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Status message"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

            <!-- Expand indicator (only visible when has subprocesses) -->
            <ImageView
                android:id="@+id/ivExpand"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_expand"
                android:visibility="gone"
                app:tint="@color/text_muted"
                android:contentDescription="Expand" />

            <!-- Configure button (only visible for configurable daemons like Zrok) -->
            <ImageView
                android:id="@+id/ivConfigure"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:padding="4dp"
                android:src="@drawable/ic_settings"
                android:visibility="gone"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/text_muted"
                android:contentDescription="Configure" />

            <!-- Download log button (only visible in debug builds) -->
            <ImageView
                android:id="@+id/ivDownloadLog"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:padding="4dp"
                android:src="@drawable/ic_download_log"
                android:visibility="gone"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/text_muted"
                android:contentDescription="Download log" />

            <!-- Toggle Switch -->
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchDaemon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- Expandable Subprocess Section -->
        <LinearLayout
            android:id="@+id/subprocessContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp"
            android:background="@color/bg_elevated">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SUBPROCESSES"
                android:textColor="@color/text_muted"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <!-- Subprocess list will be added dynamically -->
            <LinearLayout
                android:id="@+id/subprocessList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
