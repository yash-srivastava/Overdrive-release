<?xml version="1.0" encoding="utf-8"?>
<!-- First-launch setup guide dialog.
     Wrapped in ScrollView so the content + buttons are always reachable
     on landscape BYD head units (720p, ~604dp usable height). -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_surface"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Getting Started"
        android:textColor="@color/brand_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Two quick steps to get the best experience:"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <!-- Step 1: Auto-start -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/overlay_expanded_background"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/overlay_pill_background"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/brand_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Disable Auto-Start Restriction"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Uncheck 'Disable auto-start' in app settings to prevent the system from killing OverDrive in the background."
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />

            </LinearLayout>

            <ImageView
                android:id="@+id/ivAutoStartCheck"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_overlay_rec_active"
                android:visibility="invisible"
                android:contentDescription="Step completed" />

        </LinearLayout>

        <TextView
            android:id="@+id/btnOpenAutoStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/overlay_action_button_bg"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:text="Open App Settings"
            android:textColor="@color/brand_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Step 2: Overlay Permission -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/overlay_expanded_background"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/overlay_pill_background"
                android:gravity="center"
                android:text="2"
                android:textColor="@color/brand_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Allow Display Over Other Apps"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Enable this to show a floating status indicator for recording and trip tracking on top of other apps."
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />

            </LinearLayout>

            <ImageView
                android:id="@+id/ivOverlayCheck"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_overlay_rec_active"
                android:visibility="invisible"
                android:contentDescription="Permission granted" />

        </LinearLayout>

        <TextView
            android:id="@+id/btnOpenOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/overlay_action_button_bg"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:text="Open Overlay Settings"
            android:textColor="@color/brand_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Don't show again -->
    <CheckBox
        android:id="@+id/cbDontShowAgain"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Don't show this again"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:buttonTint="@color/brand_primary" />

    <!-- Action buttons — always visible, high contrast -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnSkip"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:gravity="center"
            android:paddingHorizontal="20dp"
            android:text="SKIP"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="?android:attr/selectableItemBackground" />

        <TextView
            android:id="@+id/btnDone"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:gravity="center"
            android:paddingHorizontal="28dp"
            android:background="@color/brand_primary"
            android:text="DONE"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
</ScrollView>
